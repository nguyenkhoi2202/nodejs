{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "^/login/?$",
      "dest": "/api/login.js"
    },
    {
      "src": "^/attendance/?$",
      "dest": "/api/attendance.js"
    },
    {
      "src": "^/$",
      "dest": "/api/index.js"
    }
  ]
}
